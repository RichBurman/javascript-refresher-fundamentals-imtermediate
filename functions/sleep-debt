const getSleepHours = (day) => {
  day = day.toLowerCase();
  if (day === "monday") {
    return 8;
  } else if (day === "tuesday") {
    return 9;
  } else if (day === "wednesday") {
    return 7;
  } else if (day === "thursday") {
    return 6;
  } else if (day === "friday") {
    return 8;
  } else if (day === "saturday") {
    return 10;
  } else if (day === "sunday") {
    return 11;
  }
};

