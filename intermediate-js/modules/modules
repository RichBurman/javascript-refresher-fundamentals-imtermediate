/* shape-area.js */
const { PI } = Math;

const circleArea = (radiusLength) => {
  return PI * radiusLength * radiusLength;
};

const squareArea = (sideLength) => {
  return sideLength * sideLength;
};

module.exports = { circleArea, squareArea };



